# Required: Cloudflare API Token
# Create at https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: Zone:Read, DNS:Edit, SSL:Edit, R2:Edit, Pages:Edit, LB:Edit
CLOUDFLARE_API_TOKEN=your_token_here

# Optional: R2 Object storage credentials (only needed for r2 objects commands)
# Create at Cloudflare Dashboard -> R2 -> Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: Logging
CFM_LOG_LEVEL=INFO
CFM_LOG_FILE=~/.cfmanager/cfmanager.log
